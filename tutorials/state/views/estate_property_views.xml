<?xml version="1.0" encoding="UTF-8"?>
<odoo>

    <!-- Estate.Property-->
    <record id="estate_model_action" model="ir.actions.act_window">
        <field name="name">Properties</field>
        <field name="res_model">estate.property</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_filter_available': 1}</field>
    </record>

    <record id="estate_property_views_list" model="ir.ui.view">
        <field name="name">estate.property.list</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
                        <list string="Real Estate List"
                                    decoration-success="state in ['offer_received', 'offer_accepted']"
                                    decoration-bf="state == 'offer_accepted'"
                                    decoration-muted="state == 'sold'"
                                    decoration-danger="state == 'cancelled'">
                <field name="name"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="num_bedrooms"/>
                <field name="availability_date" optional="hide"/>
                                <field name="state" invisible="1"/>
                <field name="property_type_id"/>
                <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                <field name="living_area"/>
                <field name="garden_area" invisible="not garden"/>
                <field name="total_area"/>
                <field name="best_price"/>
            </list>
        </field>
    </record>

    <record id="estate_property_views_form" model="ir.ui.view">
        <field name="name">estate.property.form</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <form string="Form Real Estate">
                <header>
                    <button name="action_set_sold" type="object" string="Sold" invisible="state in ['cancelled', 'sold']"/>
                    <button name="action_set_cancelled" type="object" string="Cancelled" invisible="state in ['sold', 'cancelled']"/>
                    <field name="state" widget="statusbar" statusbar_visible="new,offer_received,offer_accepted,sold,cancelled"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Property Name"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="num_bedrooms"/>
                            <field name="num_months"/>
                            <field name="availability_date"/>
                        </group>
                        <group>
                            <field name="tag_ids" widget="many2many_tags" options="{'color_field': 'color'}"/>
                        </group>
                        <group>
                            <field name="expected_price"/>
                            <field name="selling_price"/>
                        </group>
                        <group>
                            <field name="living_area"/>
                            <field name="total_area" readonly="1"/>
                            <field name="best_price" readonly="1"/>
                        </group>
                        <group>
                            
                            <field name="active"/>
                            <field name="property_type_id" options="{'no_create': True, 'no_create_edit': True}"/>
                        </group>
                        <group>
                            <field name="garden"/>
                            <field name="garden_area" invisible="not garden"/>
                            <field name="orientation" invisible="not garden"/>

                        </group>
                    </group>
                    <notebook>
                        <page string="Description">
                            <field name="description"/>
                        </page>
                        <page string="Other info">
                            <group>
                                <field name="buyer_id"/>
                                <field name="salesperson_id"/>
                            </group>
                        </page>
                        <page string="Offers">
                            <field name="offer_ids" readonly="state in ['offer_accepted', 'sold', 'cancelled']">
                                <list>
                                    <field name="price"/>
                                    <field name="partner_id"/>
                                    <button name="action_accept" type="object" string="Accept" icon="fa-check" invisible="status in ['accepted', 'refused'] or property_id.state in ['sold', 'cancelled']"/>
                                    <button name="action_refuse" type="object" string="Refuse" icon="fa-close" invisible="status in ['accepted', 'refused'] or property_id.state in ['sold', 'cancelled']"/>
                                    <field name="status"/>
                                    <field name="validity"/>
                                    <field name="date_deadline"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="estate_property_view_search" model="ir.ui.view">
        <field name="name">estate.property.search</field>
        <field name="model">estate.property</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="expected_price"/>
                <field name="selling_price"/>
                <field name="num_bedrooms"/>
                <field name="living_area" filter_domain="[('living_area', '>=', self)]"/>
                <field name="property_type_id"/>
                <field name="state"/>
                <field name="availability_date"/>
                <field name="active"/>
                <field name="buyer_id"/>
                <field name="salesperson_id"/>

                <filter string="Available" name="filter_available" domain="[('state', 'not in', ['sold', 'cancelled'])]"/>
                <filter string="New" name="filter_new" domain="[('state', '=', 'new')]"/>
                <filter string="Sold" name="filter_sold" domain="[('state', '=', 'sold')]"/>
                <filter string="Offer Received" name="filter_offer_received" domain="[('state', '=', 'offer_received')]"/>
                <filter string="3+ Bedrooms" name="filter_3_bedrooms" domain="[('num_bedrooms', '>=', 3)]"/>

                <separator/>
                <filter string="Group by State" name="group_by_state" context="{'group_by': 'state'}"/>
                <filter string="Group by num_bedrooms" name="group_by_num_bedrooms" context="{'group_by': 'num_bedrooms'}"/>
            </search>
        </field>
    </record>
    
</odoo>